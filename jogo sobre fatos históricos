NOMES_EVENTOS = list(EVENTOS.keys())

TOTAL_FASES = 5
DICAS_POR_FASE = 10
ALTERNATIVAS_POR_FASE = 5


def limpar_tela():
    import os
    os.system('cls' if os.name == 'nt' else 'clear')


def linha(char='-', tamanho=60):
    print(char * tamanho)


def cabecalho(fase_atual, pontos):
    limpar_tela()
    linha('=')
    print(f"  EM QUE ÉPOCA VOCÊ ESTÁ?  |  Fase {fase_atual}/{TOTAL_FASES}  |  Pontos: {pontos}")
    linha('=')
    print()


def escolher_alternativas(correto):
    outros = [n for n in NOMES_EVENTOS if n != correto]
    random.shuffle(outros)
    opcoes = [correto] + outros[:ALTERNATIVAS_POR_FASE - 1]
    random.shuffle(opcoes)
    return opcoes


def rodar_fase(numero_fase, eventos_usados, pontos):
    disponiveis = [n for n in NOMES_EVENTOS if n not in eventos_usados]
    if not disponiveis:
        disponiveis = NOMES_EVENTOS[:]

    nome_evento = random.choice(disponiveis)
    dicas = random.sample(EVENTOS[nome_evento], DICAS_POR_FASE)
    alternativas = escolher_alternativas(nome_evento)

    dicas_reveladas = []
    respondeu = False
    acertou = False
    bonus = 0

    for i, dica in enumerate(dicas):
        cabecalho(numero_fase, pontos)
        print(f"  Fase {numero_fase} — dica {i + 1} de {DICAS_POR_FASE}")
        linha()
        print()

        if dicas_reveladas:
            print("  Dicas anteriores:")
            for j, d_ant in enumerate(dicas_reveladas):
                print(f"  {j + 1}. {d_ant}")
            print()
            linha()

        print(f"\n  Dica {i + 1}: {dica}\n")
        linha()

        dicas_reveladas.append(dica)

        if i < DICAS_POR_FASE - 1:
            print("  [P] Próxima dica")
            print("  [R] Já sei! Quero responder agora")
            print()
            while True:
                escolha = input("  Sua escolha: ").strip().upper()
                if escolha in ('P', 'R'):
                    break
                print("  Digite P ou R.")

            if escolha == 'R':
                respondeu = True
                break
        else:
            print("  Você usou todas as dicas. Hora de responder!\n")
            input("  [Enter para ver as alternativas]")
            respondeu = True
            break

    cabecalho(numero_fase, pontos)
    print(f"  Fase {numero_fase} — Onde você estava?\n")
    linha()
    print()

    for idx, alt in enumerate(alternativas):
        print(f"  {idx + 1}. {alt}")

    print()
    linha()

    while True:
        try:
            escolha_num = int(input("  Digite o número da sua resposta: "))
            if 1 <= escolha_num <= len(alternativas):
                break
            print(f"  Escolha entre 1 e {len(alternativas)}.")
        except ValueError:
            print("  Digite um número válido.")

    resposta = alternativas[escolha_num - 1]
    acertou = resposta == nome_evento

    if acertou:
        bonus = max(1, DICAS_POR_FASE + 1 - len(dicas_reveladas))

    cabecalho(numero_fase, pontos + bonus if acertou else pontos)
    linha()

    if acertou:
        print(f"\n  CORRETO! Era: {nome_evento}")
        print(f"  Você usou {len(dicas_reveladas)} dica(s) e ganhou {bonus} ponto(s)!\n")
    else:
        print(f"\n  Não foi dessa vez.")
        print(f"  A resposta era: {nome_evento}")
        print(f"  Você escolheu: {resposta}\n")

    linha()
    input("\n  [Enter para continuar]")

    return acertou, bonus, nome_evento


def tela_resultado_final(resultados, pontos_total):
    limpar_tela()
    linha('=')
    print("  RESULTADO FINAL")
    linha('=')
    print()

    acertos = sum(1 for r in resultados if r['acertou'])

    print(f"  Acertos: {acertos}/{TOTAL_FASES}")
    print(f"  Pontos:  {pontos_total}")
    print()
    linha()

    for i, r in enumerate(resultados):
        simbolo = "✓" if r['acertou'] else "✗"
        print(f"  {simbolo} Fase {i + 1}: {r['evento']}")

    print()
    linha()

    if acertos == 5:
        msg = "Perfeito! Você é um viajante do tempo de verdade."
    elif acertos >= 3:
        msg = "Boa memória histórica. A história não te engana fácil."
    elif acertos >= 1:
        msg = "Você sobreviveu. A história é complicada mesmo."
    else:
        msg = "Talvez seja hora de rever aquele livro de história..."

    print(f"\n  {msg}\n")
    linha('=')


def jogar():
    limpar_tela()
    linha('=')
    print("  EM QUE ÉPOCA VOCÊ ESTÁ?")
    linha('=')
    print()
    print("  5 fases. Em cada fase você recebe dicas de um evento histórico.")
    print("  Tente acertar antes de esgotar todas as dicas.")
    print("  Quanto menos dicas usar, mais pontos você ganha!")
    print()
    linha()
    input("  [Enter para começar]")

    pontos = 0
    resultados = []
    eventos_usados = []

    for fase in range(1, TOTAL_FASES + 1):
        acertou, bonus, evento = rodar_fase(fase, eventos_usados, pontos)
        pontos += bonus
        eventos_usados.append(evento)
        resultados.append({'acertou': acertou, 'evento': evento, 'bonus': bonus})

    tela_resultado_final(resultados, pontos)

    print()
    while True:
        jogar_de_novo = input("  Jogar de novo? (s/n): ").strip().lower()
        if jogar_de_novo in ('s', 'n'):
            break

    if jogar_de_novo == 's':
        jogar()


if __name__ == "__main__":
