    ("4",  "Energia Potencial Gravitacional   Ep = m·g·h",                      energia_potencial_grav),
    ("5",  "Peso de um Corpo                  P = m · g",                       peso_corpo),
    ("6",  "MRU                               s = s₀ + v·t",                    mru),
    ("7",  "MUV                               v = v₀+a·t / Torricelli",         muv),
    ("8",  "Trabalho de uma Força             W = F·d·cos(θ)",                  trabalho_forca),
    ("9",  "Potência Mecânica                 P = W/t  ou  F·v",                potencia),
    ("10", "Quantidade de Movimento/Impulso   Q = m·v  |  I = F·Δt",           quantidade_movimento),
    ("11", "Movimento Circular (MCU)          ω = 2π/T  |  v = ω·r",           mcu),
    ("12", "Força Centrípeta                  Fc = m·v²/r",                     forca_centripeta),
    ("13", "Energia Elástica / Lei de Hooke   Ee = k·x²/2  |  F = k·x",        energia_elastica),
    ("14", "Empuxo (Arquimedes)               E = ρ·g·V",                       empuxo),
    ("15", "Pressão Hidrostática              P = ρ·g·h",                       pressao_hidrostatica),
    ("16", "Pressão                           P = F / A",                       pressao),
    ("17", "Densidade                         ρ = m / V",                       densidade),
    ("18", "Rendimento                        η = W_útil/W_total × 100%",       rendimento),
    # --- Termologia ---
    ("19", "Calor Sensível                    Q = m·c·ΔT",                      calor_sensivel),
    ("20", "Calor Latente                     Q = m · L",                       calor_latente),
    ("21", "Dilatação Térmica Linear          ΔL = L₀·α·ΔT",                   dilatacao_termica),
    ("22", "Dilatação Superficial/Volumétrica ΔA=A₀βΔT | ΔV=V₀γΔT",           dilatacao_sup_vol),
    ("23", "Gases Ideais                      P·V = n·R·T",                     gases_ideais),
    ("24", "Lei de Boyle                      P₁V₁ = P₂V₂",                    lei_boyle),
    ("25", "Lei de Charles                    V₁/T₁ = V₂/T₂",                  lei_charles),
    # --- Ondulatória e Óptica ---
    ("26", "Ondulatória                       v = λ · f",                       ondulatoria),
    ("27", "Período e Frequência              T = 1 / f",                       periodo_frequencia),
    ("28", "Óptica — Equação de Gauss         1/f = 1/p + 1/p'",               optica_gauss),
    ("29", "Refração — Índice e Snell         n = c/v  |  n₁senθ₁=n₂senθ₂",   refracao),
    # --- Eletricidade ---
    ("30", "Lei de Coulomb                    F = k·|q₁q₂| / d²",              coulomb),
    ("31", "Campo Elétrico                    E = F/q  |  E = k·Q/d²",         campo_eletrico),
    ("32", "Lei de Ohm                        V = R · I",                       lei_ohm),
    ("33", "Potência Elétrica                 P = V·I / I²R / V²/R",           potencia_eletrica),
    ("34", "Energia Elétrica                  E = P·t  (J e kWh)",             energia_eletrica),
    ("35", "Resistores Série/Paralelo         R_eq",                            resistores),
    ("36", "Transformador                     V₁/V₂ = N₁/N₂ = I₂/I₁",        transformador),
    # --- Física Moderna ---
    ("37", "Gravitação Universal              F = G·m₁·m₂ / d²",               gravitacao_universal),
    ("38", "Equação de Einstein               E = m · c²",                      einstein),
    ("39", "Efeito Fotoelétrico               E = h·f  |  Ec = hf - φ",        efeito_fotoeletrico),
    ("40", "Decaimento Radioativo             N = N₀·(1/2)^(t/T½)",            decaimento_radioativo),
]

CATEGORIAS = {
    "MECÂNICA":       [str(i) for i in range(1, 19)],
    "TERMOLOGIA":     [str(i) for i in range(19, 26)],
    "ONDAS / ÓPTICA": [str(i) for i in range(26, 30)],
    "ELETRICIDADE":   [str(i) for i in range(30, 37)],
    "FÍSICA MODERNA": [str(i) for i in range(37, 41)],
}

def mostrar_menu():
    print("\n" + "=" * 63)
    print("         ASSISTENTE DE FÍSICA  — ENSINO MÉDIO")
    print("=" * 63)
    mapa_num = {num: nome for num, nome, _ in MENU}
    for cat, nums in CATEGORIAS.items():
        print(f"\n  ── {cat} ──")
        for n in nums:
            print(f"    {n:>2}. {mapa_num[n]}")
    print("\n   0. Sair")
    print("=" * 63)

def main():
    mapa = {num: func for num, _, func in MENU}
    while True:
        mostrar_menu()
        escolha = input("\n  Escolha o número do tema: ").strip()
        if escolha == "0":
            print("\n  Bons estudos! Até logo.\n")
            break
        elif escolha in mapa:
            try:
                mapa[escolha]()
            except ZeroDivisionError:
                print("\n  !! Erro: divisão por zero. Verifique os valores.")
            except ValueError as e:
                print(f"\n  !! Erro de valor: {e}")
            input("\n  [Enter para continuar]")
        else:
            print("  Opção inválida. Tente novamente.")

if __name__ == "__main__":
    main()
