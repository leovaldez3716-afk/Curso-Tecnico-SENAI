def equilibrio():
    print(titulo("EQUILÍBRIO QUÍMICO"))
    print("  1. Ebulioscopia (Elevação Ebulição)     ΔTe = Ke × i × m")
    print("  2. Crioscopia (Abaixamento Fusão)        ΔTc = Kc × i × m")
    print("  3. Osmoscopia (Pressão Osmótica)         π = MRT")
    print("  4. Tonoscopia (Abaixamento de P. de Vapor)")
    print("  5. Calcular Massa Molar por ebulioscopio/crioscopio")
    print("  6. Fator i de Vant Hoff")
    print("  7. Tabela de Constantes dos Solventes")
    print("  8. Voltar")    
    op = input_str("Escolha")

    if op == "1":
        print(subtitulo("Constante Kc"))
        print(info("Insira concentrações e expoentes dos produtos e reagentes."))
        try:
            cp = [float(x) for x in input_str("[Produtos] (mol/L) separados por vírgula").split(",")]
            ep = [float(x) for x in input_str("Expoentes dos produtos").split(",")]
            cr = [float(x) for x in input_str("[Reagentes] (mol/L) separados por vírgula").split(",")]
            er = [float(x) for x in input_str("Expoentes dos reagentes").split(",")]
            num = 1
            for c_, e_ in zip(cp, ep): num *= c_**e_
            den = 1
            for c_, e_ in zip(cr, er): den *= c_**e_
            Kc = num/den
            print(result("Kc", f"{Kc:.4e}"))
            if Kc > 1: print(info("Kc > 1 → Equilíbrio favorece PRODUTOS"))
            else:       print(info("Kc < 1 → Equilíbrio favorece REAGENTES"))
        except: print(err("Erro de entrada."))

    elif op == "2":
        print(subtitulo("Kp = Kc × (RT)^Δn"))
        Kc = input_num("Kc")
        T_ = input_num("T (K)")
        dn = input_num("Δn (mols gasosos: produtos - reagentes)")
        R_ = 0.082
        Kp = Kc * (R_*T_)**dn
        print(result("Kp", f"{Kp:.4e}"))
        Kc2 = input_num("Ou: converta Kp → Kc (Kp = ?)", allow_empty=True)
        if Kc2 is not None:
            Kc_calc = Kc2 / (R_*T_)**dn
            print(result("Kc", f"{Kc_calc:.4e}"))

    elif op == "3":
        print(subtitulo("Grau de Dissociação α"))
        ni  = input_num("Moles iniciais")
        nd  = input_num("Moles dissociados no equilíbrio")
        al  = nd/ni*100
        print(result("α", f"{al:.2f}", "%"))

    elif op == "4":
        print(subtitulo("Tabela ICE  aA + bB ⇌ cC + dD"))
        print(info("Kc simplificado — monoprotico. Deixe c_inicial dos produtos = 0"))
        Kc = input_num("Kc da reação")
        A0 = input_num("[A]₀ (mol/L) — concentração inicial")
        # Simplificado para aA ⇌ cC
        a_ = input_num("coef. de A (ex: 1)")
        c_ = input_num("coef. de C (ex: 1 ou 2)")
        # Kc = (c_*x)^c / (A0 - a_*x)^a  
        print(info("Aproximação: x << A0 → Kc ≈ x^c / A0^a"))
        try:
            x = (Kc * A0**a_)**(1/c_)
            A_eq = A0 - a_*x
            C_eq = c_*x
            resultado_box("ICE", [
                f"x = {cor(f'{x:.6f}', C.CYAN)}",
                f"[A]eq = {A0} - {a_}x = {cor(f'{A_eq:.4f} mol/L', C.GREEN)}",
                f"[C]eq = {c_}x   = {cor(f'{C_eq:.4f} mol/L', C.GREEN)}",
            ])
        except: print(err("Não foi possível calcular. Tente Kc diferente."))

    elif op == "5":
        print(subtitulo("Princípio de Le Chatelier"))
        print(f"  {cor(f'{'PERTURBAÇÃO':<40}', C.YELLOW)} {cor('DESLOCAMENTO', C.GREEN)}")
        print("  " + "─" * 70)
        print("  Adição de reagente                       → Favorece produção de PRODUTOS")
        print("  Adição de produto                        → Favorece produção de REAGENTES")
        print("  Remoção de reagente                      → Favorece produção de REAGENTES")
        print("  Remoção de produto                       → Favorece produção de PRODUTOS")
        print("  Aumento de pressão                       → Favorece o lado com MENOS mols gás")
        print("  Diminuição de pressão                    → Favorece o lado com MAIS mols gás")
        print("  Aumento de T (reação exotérmica ΔH<0)    → Favorece REAGENTES (K diminui)")
        print("  Aumento de T (reação endotérmica ΔH>0)   → Favorece PRODUTOS  (K aumenta)")
        print("  Diminuição de T (reação exotérmica)      → Favorece PRODUTOS  (K aumenta)")
        print(f"  Catalisador adicionado                   → {cor('NÃO DESLOCA', C.RED)} (só acelera)")
        print("  Gás inerte adicionado (V=cte)            → Sem efeito")
        print("  Diluição (aumento de V)                  → Favorece lado com MAIS mols gás")
