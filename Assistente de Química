        resultado_box("COEFICIENTE DE SOLUBILIDADE", [
            f"CS = ({ms}/{mv}) × 100",
            f"CS = {cor(f'{cs:.4f} g / 100g solvente', C.GREEN, C.BOLD)}",
        ])
    elif op == "2":
        print(subtitulo("Tipo de Solução"))
        dis = input_num("Massa de soluto que você dissolveu (g/100g solvente)")
        cs  = input_num("Coeficiente de solubilidade CS da substância (g/100g solvente)")
        if dis < cs:
            print(ok(f"Solução INSATURADA — pode dissolver mais {cs-dis:.4f} g"))
        elif abs(dis - cs) < 1e-9:
            print(warn("Solução SATURADA — no limite exato de solubilidade"))
        else:
            print(err(f"Solução SUPERSATURADA — {dis-cs:.4f} g em excesso; instável, cristaliza ao agitar"))

    elif op == "3":
        print(subtitulo("Solubilidades Comuns (g/100g H₂O)"))
        print(cor(f"{'Substância':<18}", C.YELLOW), cor(f"{'CS':>10}", C.YELLOW), cor(f"{'T':>5}", C.YELLOW), cor("Observação", C.YELLOW))
        separador()
        for k, v in SOLUBILIDADES.items():
            print(f"  {cor(k, C.CYAN):<26} {cor(str(v['cs']).rjust(8), C.GREEN)}  {str(v['temp']+'°C').rjust(5) if isinstance(v['temp'],str) else str(v['temp'])+'°C':>5}  {cor(v['obs'], C.GRAY)}")

    elif op == "4":
        print(subtitulo("Produto de Solubilidade  Kps = [cátion]^a × [ânion]^b"))
        print(info("Kps comuns: BaSO4=1,1e-10 | AgCl=1,8e-10 | CaCO3=3,3e-9 | PbS=9,0e-29"))
        kps = input_num("Valor de Kps (ex: 1.8e-10)")
        a   = input_num("Coeficiente estequiométrico do cátion (a)", default=1)
        b_  = input_num("Coeficiente estequiométrico do ânion (b)", default=1)
        # AxBy → a[A^(b+)] + b[B^(a-)]
        # Kps = (a·s)^a · (b·s)^b = a^a · b^b · s^(a+b)
        n = a + b_
        s = (kps / (a**a * b_**b_)) ** (1/n)
        resultado_box("SOLUBILIDADE MOLAR", [
            f"Kps = {kps:.4e}",
            f"s^{int(n)} = Kps / ({int(a)}^{int(a)} × {int(b_)}^{int(b_)})",
            f"s  = {cor(f'{s:.6e} mol/L', C.GREEN, C.BOLD)}",
        ])

