def mmc(a, b):
    from math import gcd
    return a * b // gcd(a, b)

def neutralizacao():
    print(titulo("NEUTRALIZAÇÃO ÁCIDO-BASE"))
    print(f"\n{cor('  ÁCIDOS DISPONÍVEIS:', C.YELLOW)}")
    acids_list = list(ACIDOS.keys())
    for i, k in enumerate(acids_list):
        print(f"  {cor(str(i+1).rjust(2), C.CYAN)}. {k:<12} — {ACIDOS[k]['nome']} ({ACIDOS[k]['tipo']})")
    print(f"\n{cor('  BASES DISPONÍVEIS:', C.YELLOW)}")
    bases_list = list(BASES.keys())
    for i, k in enumerate(bases_list):
        print(f"  {cor(str(i+1).rjust(2), C.CYAN)}. {k:<14} — {BASES[k]['nome']} ({BASES[k]['tipo']})")

    print()
    acid_str = input_str("Digite a fórmula do ácido (ex: HCl, H2SO4)")
    if acid_str not in ACIDOS:
        print(err(f"Ácido '{acid_str}' não encontrado."))
        return
    base_str = input_str("Digite a fórmula da base (ex: NaOH, Ca(OH)2)")
    if base_str not in BASES:
        print(err(f"Base '{base_str}' não encontrada."))
        return

    a = ACIDOS[acid_str]
    b = BASES[base_str]
    na, nb = a["n"], b["n"]
    lc = mmc(na, nb)
    ca_coef = lc // na
    cb_coef = lc // nb
    n_agua = lc
    cation = b["cation"].replace("⁺","").replace("²","").replace("³","").replace("+","").strip()
    salt_name = f"{cation} {a['salt']}"

    print()
    print(cor("  ╔══════════════════════════════════════════════════╗", C.CYAN))
    print(cor("  ║           EQUAÇÃO BALANCEADA                    ║", C.CYAN))
    print(cor("  ╚══════════════════════════════════════════════════╝", C.CYAN))
    prefix_a = str(ca_coef) if ca_coef > 1 else ""
    prefix_b = str(cb_coef) if cb_coef > 1 else ""
    prefix_h = str(n_agua) if n_agua > 1 else ""
    eq = (f"\n  {cor(prefix_a + acid_str, C.GREEN, C.BOLD)}  +  "
          f"{cor(prefix_b + base_str, C.BLUE, C.BOLD)}  →  "
          f"{cor(salt_name, C.YELLOW, C.BOLD)}  +  "
          f"{cor(prefix_h + 'H₂O', C.CYAN)}\n")
    print(eq)
    print(info(f"Ácido: {a['nome']} ({a['tipo']}) — {na}-ácido (nox = {na})"))
    print(info(f"Base:  {b['nome']} ({b['tipo']}) — {nb}-básica (nox = {nb})"))
    print(info(f"MCM({na},{nb}) = {lc} → coef. ácido = {ca_coef}, coef. base = {cb_coef}, {n_agua} mol H₂O"))

    print(f"\n{cor('  CÁLCULO QUANTITATIVO', C.YELLOW)}")
    calc_q = input_str("Deseja calcular volumes/concentrações? (s/n)").lower()
    if calc_q == 's':
        print(f"\n  {cor('— Dados do ÁCIDO —', C.GREEN)}")
        va = input_num("Volume do ácido (mL)", allow_empty=True)
        ca = input_num("Concentração do ácido (mol/L)", allow_empty=True)
        print(f"  {cor('— Dados da BASE —', C.BLUE)}")
        vb = input_num("Volume da base (mL)", allow_empty=True)
        cb = input_num("Concentração da base (mol/L)", allow_empty=True)

        dados = {"va":va,"ca":ca,"vb":vb,"cb":cb}
        vazios = [k for k,v in dados.items() if v is None]

        if len(vazios) == 0:
            # Análise completa
            eq_a = ca * va/1000 * na
            eq_b = cb * vb/1000 * nb
            diff = eq_a - eq_b
            linhas = [
                f"{cor('nEq(ácido)', C.GRAY)} = {ca} × {va}/1000 × {na} = {cor(f'{eq_a:.4f} eq', C.GREEN)}",
                f"{cor('nEq(base)', C.GRAY)}  = {cb} × {vb}/1000 × {nb} = {cor(f'{eq_b:.4f} eq', C.GREEN)}",
                "",
            ]
            if abs(diff) < 1e-9:
                linhas.append(cor("✔ NEUTRALIZAÇÃO COMPLETA — ponto de equivalência", C.GREEN, C.BOLD))
                linhas.append(cor("  pH ≈ 7,0 (solução neutra)", C.CYAN))
            elif diff > 0:
                linhas.append(cor(f"⚠ EXCESSO DE ÁCIDO: {diff:.4f} eq", C.RED))
                linhas.append(cor("  pH < 7,0 (solução ácida)", C.RED))
            else:
                linhas.append(cor(f"⚠ EXCESSO DE BASE: {abs(diff):.4f} eq", C.YELLOW))
                linhas.append(cor("  pH > 7,0 (solução básica)", C.YELLOW))
            resultado_box("ANÁLISE DE NEUTRALIZAÇÃO", linhas)
        elif len(vazios) == 1:
            k = vazios[0]
            try:
                if k == "va":
                    res = (cb * vb/1000 * nb) / (ca * na) * 1000
                    print(result(f"Volume do ácido", f"{res:.4f}", "mL"))
                elif k == "ca":
                    res = (cb * vb/1000 * nb) / (va/1000 * na)
                    print(result(f"Concentração do ácido", f"{res:.6f}", "mol/L"))
                elif k == "vb":
                    res = (ca * va/1000 * na) / (cb * nb) * 1000
                    print(result(f"Volume da base", f"{res:.4f}", "mL"))
                elif k == "cb":
                    res = (ca * va/1000 * na) / (vb/1000 * nb)
                    print(result(f"Concentração da base", f"{res:.6f}", "mol/L"))
            except ZeroDivisionError:
                print(err("Divisão por zero. Verifique os valores."))

