# ─────────────────────────────────────────────────────────────────────────────
# CORES ANSI PARA TERMINAL
# ─────────────────────────────────────────────────────────────────────────────
class C:
    RESET  = "\033[0m"
    BOLD   = "\033[1m"
    DIM    = "\033[2m"
    CYAN   = "\033[96m"
    GREEN  = "\033[92m"
    YELLOW = "\033[93m"
    RED    = "\033[91m"
    BLUE   = "\033[94m"
    MAGENTA= "\033[95m"
    WHITE  = "\033[97m"
    GRAY   = "\033[90m"
    BG_DARK= "\033[40m"
    BG_BLUE= "\033[44m"
    ULINE  = "\033[4m"

def cor(texto, *estilos):
    return "".join(estilos) + str(texto) + C.RESET

def titulo(texto, width=78):
    linha = "═" * width
    padding = (width - len(texto) - 2) // 2
    return (
        f"\n{cor(linha, C.CYAN)}\n"
        f"{cor(' ' * padding + '◈ ' + texto + ' ◈', C.CYAN, C.BOLD)}\n"
        f"{cor(linha, C.CYAN)}"
    )

def subtitulo(texto):
    return f"\n{cor('▸ ' + texto, C.YELLOW, C.BOLD)}\n{cor('─' * 60, C.GRAY)}"

def ok(msg):    return f"  {cor('✔', C.GREEN)} {msg}"
def err(msg):   return f"  {cor('✘', C.RED)} {msg}"
def info(msg):  return f"  {cor('ℹ', C.CYAN)} {msg}"
def warn(msg):  return f"  {cor('⚠', C.YELLOW)} {msg}"
def result(label, valor, unit=""):
    return f"\n  {cor(label + ':', C.GRAY)} {cor(str(valor) + (' ' + unit if unit else ''), C.GREEN, C.BOLD)}"
def resultado_box(titulo_r, linhas):
    w = 60
    print(f"\n  {cor('┌' + '─'*(w-2) + '┐', C.CYAN)}")
    print(f"  {cor('│', C.CYAN)} {cor(titulo_r.center(w-4), C.CYAN, C.BOLD)} {cor('│', C.CYAN)}")
    print(f"  {cor('├' + '─'*(w-2) + '┤', C.CYAN)}")
    for l in linhas:
        padding_r = w - 4 - len(re.sub(r'\033\[[0-9;]*m', '', l))
        print(f"  {cor('│', C.CYAN)} {l}{' '*max(0,padding_r)} {cor('│', C.CYAN)}")
    print(f"  {cor('└' + '─'*(w-2) + '┘', C.CYAN)}")

def limpar():
    os.system('cls' if os.name == 'nt' else 'clear')

def input_num(prompt, default=None, allow_empty=False):
    while True:
        try:
            val = input(f"  {cor('►', C.CYAN)} {prompt}: ").strip()
            if val == "" and allow_empty:
                return None
            if val == "" and default is not None:
                return default
            return float(val.replace(",", "."))
        except ValueError:
            print(err("Valor inválido. Digite um número."))

def input_str(prompt):
    return input(f"  {cor('►', C.CYAN)} {prompt}: ").strip()

def pausar():
    input(f"\n  {cor('[Pressione ENTER para continuar]', C.GRAY)}")

def separador():
    print(cor("  " + "─" * 60, C.GRAY))

