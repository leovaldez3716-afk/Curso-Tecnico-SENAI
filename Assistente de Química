def gases():
    print(titulo("GASES"))
    print("  1. Lei Geral dos Gases      P₁V₁/T₁ = P₂V₂/T₂")
    print("  2. Gás Ideal (Clapeyron)    PV = nRT")
    print("  3. Lei de Boyle              P₁V₁ = P₂V₂  (T=cte)")
    print("  4. Lei de Charles            V₁/T₁ = V₂/T₂ (P=cte)")
    print("  5. Lei de Gay-Lussac         P₁/T₁ = P₂/T₂ (V=cte)")
    print("  6. Lei de Dalton             P_total = ΣPᵢ")
    print("  7. Velocidade RMS            v_rms = √(3RT/M)")
    print("  8. Difusão de Graham         v₁/v₂ = √(M₂/M₁)")
    print("  9. Voltar")    
    R = 0.082  # atm·L/mol·K
    R_J = 8.314  # J/mol·K
    op = input_str("Escolha")

    if op == "1":
        print(subtitulo("Lei Geral P₁V₁/T₁ = P₂V₂/T₂ — deixe 1 campo vazio"))
        print(info("T em Kelvin: T(K) = T(°C) + 273"))
        P1=input_num("P₁ (atm)",allow_empty=True); V1=input_num("V₁ (L)",allow_empty=True); T1=input_num("T₁ (K)",allow_empty=True)
        P2=input_num("P₂ (atm)",allow_empty=True); V2=input_num("V₂ (L)",allow_empty=True); T2=input_num("T₂ (K)",allow_empty=True)
        vals = {"P₁":P1,"V₁":V1,"T₁":T1,"P₂":P2,"V₂":V2,"T₂":T2}
        vazios = [k for k,v in vals.items() if v is None]
        if len(vazios) != 1:
            print(err("Deixe exatamente 1 campo vazio.")); return
        k = vazios[0]
        try:
            if k=="P₁":   res=P2*V2*T1/(T2*V1)
            elif k=="V₁": res=P2*V2*T1/(T2*P1)
            elif k=="T₁": res=P1*V1*T2/(P2*V2)
            elif k=="P₂": res=P1*V1*T2/(T1*V2)
            elif k=="V₂": res=P1*V1*T2/(T1*P2)
            else:          res=P2*V2*T1/(P1*V1)
            print(result(k, f"{res:.4f}"))
        except: print(err("Erro de cálculo."))

    elif op == "2":
        print(subtitulo("Equação de Clapeyron  PV = nRT  (R = 0,082 atm·L/mol·K)"))
        P=input_num("P (atm) — vazio para calcular",allow_empty=True)
        V=input_num("V (L) — vazio para calcular",allow_empty=True)
        n=input_num("n (mol) — vazio para calcular",allow_empty=True)
        T=input_num("T (K) — vazio para calcular",allow_empty=True)
        try:
            if P is None:  res=n*R*T/V; print(result("P",f"{res:.4f}","atm"))
            elif V is None:res=n*R*T/P; print(result("V",f"{res:.4f}","L"))
            elif n is None:res=P*V/(R*T);print(result("n",f"{res:.4f}","mol"))
            elif T is None:res=P*V/(n*R);print(result("T",f"{res:.4f}","K"),info(f"{res-273.15:.2f} °C"))
        except: print(err("Erro de cálculo."))

    elif op == "3":
        print(subtitulo("Lei de Boyle  P₁V₁ = P₂V₂ (T constante)"))
        P1=input_num("P₁ — vazio para calcular",allow_empty=True); V1=input_num("V₁",allow_empty=True if P1 else False)
        P2=input_num("P₂ — vazio para calcular",allow_empty=True); V2=input_num("V₂",allow_empty=True if P2 else False)
        try:
            if P1 is None: res=P2*V2/V1; print(result("P₁",f"{res:.4f}"))
            elif V1 is None:res=P2*V2/P1;print(result("V₁",f"{res:.4f}"))
            elif P2 is None:res=P1*V1/V2;print(result("P₂",f"{res:.4f}"))
            else:           res=P1*V1/P2;print(result("V₂",f"{res:.4f}"))
        except: print(err("Erro."))

    elif op == "4":
        print(subtitulo("Lei de Charles  V₁/T₁ = V₂/T₂ (P constante)"))
        V1=input_num("V₁",allow_empty=True); T1=input_num("T₁ (K)",allow_empty=True)
        V2=input_num("V₂",allow_empty=True); T2=input_num("T₂ (K)",allow_empty=True)
        vazios=[k for k,v in{"V₁":V1,"T₁":T1,"V₂":V2,"T₂":T2}.items() if v is None]
        if len(vazios)!=1: print(err("Deixe 1 vazio.")); return
        k=vazios[0]
        if k=="V₁":  res=V2*T1/T2
        elif k=="T₁":res=V1*T2/V2
        elif k=="V₂":res=V1*T2/T1
        else:         res=V2*T1/V1
        print(result(k,f"{res:.4f}"))

    elif op == "5":
        print(subtitulo("Lei de Gay-Lussac  P₁/T₁ = P₂/T₂ (V constante)"))
        P1=input_num("P₁",allow_empty=True); T1=input_num("T₁ (K)",allow_empty=True)
        P2=input_num("P₂",allow_empty=True); T2=input_num("T₂ (K)",allow_empty=True)
        vazios=[k for k,v in{"P₁":P1,"T₁":T1,"P₂":P2,"T₂":T2}.items() if v is None]
        if len(vazios)!=1: print(err("Deixe 1 vazio.")); return
        k=vazios[0]
        if k=="P₁":  res=P2*T1/T2
        elif k=="T₁":res=P1*T2/P2
        elif k=="P₂":res=P1*T2/T1
        else:         res=P2*T1/P1
        print(result(k,f"{res:.4f}"))

    elif op == "6":
        print(subtitulo("Lei de Dalton  P_total = ΣPᵢ"))
        Ptot = input_num("Pressão total (atm)")
        n_ = int(input_num("Quantos gases?", default=3))
        moles = []
        for i in range(n_):
            moles.append(input_num(f"n_{i+1} (mol)"))
        total_mol = sum(moles)
        print()
        for i, n_i in enumerate(moles):
            Xi = n_i / total_mol
            Pi = Xi * Ptot
            print(f"  Gás {i+1}: X = {Xi:.4f}  →  P_{i+1} = {cor(f'{Pi:.4f} atm', C.GREEN)}")

    elif op == "7":
        print(subtitulo("Velocidade Quadrática Média  v_rms = √(3RT/M)"))
        T = input_num("Temperatura T (K)")
        M = input_num("Massa Molar M (kg/mol) — ex: H2 = 0.002")
        v = math.sqrt(3 * R_J * T / M)
        print(result("v_rms", f"{v:.2f}", "m/s"))

    elif op == "8":
        print(subtitulo("Lei de Graham  v₁/v₂ = √(M₂/M₁)"))
        M1 = input_num("M₁ (g/mol)")
        M2 = input_num("M₂ (g/mol)")
        razao = math.sqrt(M2 / M1)
        print(result("v₁/v₂", f"{razao:.4f}"), info(f"Gás 1 difunde {razao:.2f}x mais {'rápido' if razao>1 else 'lento'} que gás 2"))

