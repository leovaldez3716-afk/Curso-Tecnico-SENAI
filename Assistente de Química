_SYM_TO_Z = {v["sym"].upper(): k for k, v in ELEMENTOS.items()}
_NOME_TO_Z = {v["nome"].lower(): k for k, v in ELEMENTOS.items()}

def buscar_elemento(query: str) -> Optional[dict]:
    q = query.strip()
    # Por número atômico
    try:
        z = int(q)
        if z in ELEMENTOS:
            return ELEMENTOS[z]
    except ValueError:
        pass
    # Por símbolo
    if q.upper() in _SYM_TO_Z:
        return ELEMENTOS[_SYM_TO_Z[q.upper()]]
    # Por nome
    if q.lower() in _NOME_TO_Z:
        return ELEMENTOS[_NOME_TO_Z[q.lower()]]
    # Busca parcial por nome
    for k, v in ELEMENTOS.items():
        if q.lower() in v["nome"].lower():
            return v
    return None

