def calcular_massa_molar(formula: str) -> float:
    """Parse simples de fórmula química e calcula massa molar."""
    def parse(f, idx=0):
        total = 0.0
        while idx < len(f):
            if f[idx] == '(':
                sub, idx = parse(f, idx+1)
                num = 0
                while idx < len(f) and f[idx].isdigit():
                    num = num*10 + int(f[idx]); idx += 1
                total += sub * (num if num else 1)
            elif f[idx] == ')':
                return total, idx+1
            elif f[idx].isupper():
                sym = f[idx]; idx += 1
                while idx < len(f) and f[idx].islower():
                    sym += f[idx]; idx += 1
                num = 0
                while idx < len(f) and f[idx].isdigit():
                    num = num*10 + int(f[idx]); idx += 1
                count = num if num else 1
                el = buscar_elemento(sym)
                if el: total += el['massa'] * count
                else: return -1, idx
            else:
                idx += 1
        return total, idx
    mm, _ = parse(formula)
    return mm

