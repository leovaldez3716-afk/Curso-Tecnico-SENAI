        Nt = N0 * (0.5 ** n_mv)
        resultado_box("DECAIMENTO POR MEIAS-VIDAS", [
            f"Meias-vidas = {t_}/{t12} = {cor(f'{n_mv:.2f}', C.CYAN)}",
            f"N(t) = {N0} × (1/2)^{n_mv:.2f}",
            f"N(t) = {cor(f'{Nt:.4f}', C.GREEN, C.BOLD)}",
            f"Restante = {cor(f'{Nt/N0*100:.2f}%', C.YELLOW)}",
            f"Decaiu  = {cor(f'{(1-Nt/N0)*100:.2f}%', C.RED)}",
        ])

