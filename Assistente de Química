def estequiometria():
    print(titulo("ESTEQUIOMETRIA"))
    print("  1. Cálculo Estequiométrico")
    print("  2. Reagente Limitante e Reagente em Excesso")
    print("  3. Rendimento Percentual")
    print("  4. Mol, Massa, Volume (CNTP) e Partículas")
    print("  5. Fórmula Mínima e Percentagem em Massa")
    print("  6. Voltar")
    op = input_str("Escolha")
    NA = 6.022e23

    if op == "1":
        print(subtitulo("Cálculo Estequiométrico"))
        print(info("Fórmula: Reagente A → Produto B"))
        ca = input_num("Coeficiente de A (reagente)", default=1)
        cb = input_num("Coeficiente de B (produto)", default=1)
        mma = input_num("Massa Molar de A (g/mol)")
        mmb = input_num("Massa Molar de B (g/mol)")
        ma = input_num("Massa de A fornecida (g)")
        rend = input_num("Rendimento % (padrão=100)", default=100)
        n_a = ma / mma
        n_b_teo = n_a * cb / ca
        m_b_teo = n_b_teo * mmb
        m_b_real = m_b_teo * rend / 100
        v_cntp = n_b_teo * 22.4
        n_part = n_b_teo * NA
        resultado_box("CÁLCULO ESTEQUIOMÉTRICO", [
            f"n(A) = {ma}/{mma} = {cor(f'{n_a:.4f}', C.CYAN)} mol",
            f"n(B) = {n_a:.4f} × {cb}/{ca} = {cor(f'{n_b_teo:.4f}', C.CYAN)} mol",
            f"m(B) teórico = {cor(f'{m_b_teo:.4f} g', C.GREEN, C.BOLD)}",
            f"m(B) real ({rend}%) = {cor(f'{m_b_real:.4f} g', C.YELLOW, C.BOLD)}",
            f"V(B) no CNTP = {cor(f'{v_cntp:.4f} L', C.GREEN)}",
            f"N(B) partículas = {cor(f'{n_part:.3e}', C.MAGENTA)}",
        ])

    elif op == "2":
        print(subtitulo("Reagente Limitante"))
        ca = input_num("Coef. reagente 1")
        m1 = input_num("Massa reagente 1 (g)")
        mm1 = input_num("MM reagente 1 (g/mol)")
        cb = input_num("Coef. reagente 2")
        m2 = input_num("Massa reagente 2 (g)")
        mm2 = input_num("MM reagente 2 (g/mol)")
        r1 = (m1/mm1)/ca
        r2 = (m2/mm2)/cb
        lim = "Reagente 1" if r1 < r2 else "Reagente 2"
        exc = "Reagente 2" if r1 < r2 else "Reagente 1"
        r_lim = min(r1,r2)
        r_exc = max(r1,r2)
        excesso_mol = (r_exc - r_lim) * (cb if lim=="Reagente 1" else ca)
        excesso_g = excesso_mol * (mm2 if lim=="Reagente 1" else mm1)
        resultado_box("REAGENTE LIMITANTE", [
            f"Razão A = {m1/mm1:.4f}/{ca} = {cor(f'{r1:.4f}', C.CYAN)}",
            f"Razão B = {m2/mm2:.4f}/{cb} = {cor(f'{r2:.4f}', C.CYAN)}",
            f"Reagente Limitante = {cor(lim, C.RED, C.BOLD)}",
            f"Reagente em Excesso = {cor(exc, C.YELLOW)}",
            f"Excesso = {cor(f'{excesso_g:.4f} g', C.GRAY)} do reagente em excesso sobra",
        ])

    elif op == "3":
        print(subtitulo("Rendimento Percentual"))
        m_real = input_num("Quantidade real obtida (g ou mol)")
        m_teo  = input_num("Quantidade teórica esperada (g ou mol)")
        rend   = m_real / m_teo * 100
        resultado_box("RENDIMENTO", [
            f"% rend = ({m_real}/{m_teo}) × 100",
            f"% rend = {cor(f'{rend:.2f}%', C.GREEN, C.BOLD)}",
        ])

    elif op == "4":
        print(subtitulo("Mol ↔ Massa ↔ Volume ↔ Partículas"))
        print(
  {cor('a)', C.CYAN)}," mol → massa (n × MM)",
  {cor('b)', C.CYAN)}," mol → volume CNTP (n × 22,4)",
  {cor('c)', C.CYAN)}," mol → partículas (n × 6,022×10²³)",
  {cor('d)', C.CYAN)} ,"massa → mol (m / MM)"
        )
        mm = input_num("Massa Molar MM (g/mol)")
        n_  = input_num("Número de moles (n)")
        resultado_box("CONVERSÕES", [
            f"Massa      = n × MM = {n_:.4f} × {mm} = {cor(f'{n_*mm:.4f} g', C.GREEN, C.BOLD)}",
            f"Vol. CNTP  = n × 22,4 = {cor(f'{n_*22.4:.4f} L', C.GREEN)}",
            f"Partículas = n × Nₐ = {cor(f'{n_*NA:.4e}', C.MAGENTA)}",
        ])

    elif op == "5":
        print(subtitulo("Fórmula Mínima — Composição Percentual"))
        print(info("Digite as % em massa dos elementos (somam 100%)"))
        elementos_comp = []
        while True:
            sym = input_str("Símbolo do elemento (ENTER para finalizar)")
            if not sym: break
            el = buscar_elemento(sym)
            if el is None:
                print(err("Elemento não encontrado.")); continue
            pct = input_num(f"% em massa de {el['nome']}")
            elementos_comp.append((el['nome'], el['massa'], pct))

        if elementos_comp:
            print()
            ratios = [(nome, pct/mm) for nome, mm, pct in elementos_comp]
            min_r  = min(r for _,r in ratios)
            norm   = [(nome, r/min_r) for nome, r in ratios]
            # Arredondar para inteiro mais próximo
            import fractions
            print(cor("  Fórmula mínima:", C.YELLOW))
            formula = ""
            for nome, coef in norm:
                f_ = fractions.Fraction(coef).limit_denominator(12)
                print(f"    {nome}: {coef:.3f} ≈ {f_}")
                formula += f"{nome.split()[0]}{int(round(coef)) if round(coef)>1 else ''}"
            print(result("Fórmula mínima aproximada", formula))

