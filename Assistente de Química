def concentracao():
    print(titulo("CONCENTRAÇÃO DE SOLUÇÕES"))
    print("""
  1. Concentração Comum        C = m / V
  2. Concentração Molar        M = n / V  =  m / (MM × V)
  3. Diluição                  C₁V₁ = C₂V₂
  4. Título em Massa           τ = m_soluto / m_solução
  5. Fração Molar              X = n_soluto / n_total
  6. Mistura de Soluções       C_f = (C₁V₁ + C₂V₂)/(V₁+V₂)
  7. Molalidade                m = n_soluto / m_solvente(kg)
  8. Voltar
    """.format(b=C.CYAN+C.BOLD, r=C.RESET))
    op = input_str("Escolha")
    if op == "1":
        print(subtitulo("Concentração Comum  C = m / V  [g/L]"))
        m = input_num("Massa do soluto (g) — deixe em branco para calcular", allow_empty=True)
        V = input_num("Volume da solução (L) — deixe em branco para calcular", allow_empty=True)
        C_ = input_num("Concentração C (g/L) — deixe em branco para calcular", allow_empty=True)
        vazios = [x for x in [m,V,C_] if x is None]
        if len(vazios) != 1:
            print(err("Deixe exatamente 1 campo em branco.")); return
        if m is None:   print(result("Massa soluto", f"{V*C_:.4f}", "g"),  info(f"m = V × C = {V} × {C_}"))
        elif V is None: print(result("Volume solução", f"{m/C_:.4f}", "L"), info(f"V = m / C = {m} / {C_}"))
        else:           print(result("Concentração", f"{m/V:.4f}", "g/L"), info(f"C = m / V = {m} / {V}"))

    elif op == "2":
        print(subtitulo("Concentração Molar  M = n / V = m / (MM × V)"))
        m = input_num("Massa do soluto (g) — vazio para calcular", allow_empty=True)
        MM = input_num("Massa Molar MM (g/mol) — vazio para calcular", allow_empty=True)
        V = input_num("Volume da solução (L) — vazio para calcular", allow_empty=True)
        M_ = input_num("Molaridade M (mol/L) — vazio para calcular", allow_empty=True)
        if m is not None and MM is not None and V is not None:
            n = m / MM
            M_calc = n / V
            resultado_box("CONCENTRAÇÃO MOLAR", [
                f"n = {m}/{MM} = {cor(f'{n:.4f}', C.GREEN)} mol",
                f"M = {n:.4f}/{V} = {cor(f'{M_calc:.6f} mol/L', C.GREEN, C.BOLD)}",
            ])
        elif M_ is not None and MM is not None and V is not None and m is None:
            massa = M_ * MM * V
            print(result("Massa do soluto", f"{massa:.4f}", "g"))
        elif M_ is not None and m is not None and MM is not None and V is None:
            Vcalc = m / (MM * M_)
            print(result("Volume da solução", f"{Vcalc:.4f}", "L"))
        else:
            print(err("Combinação inválida."))

    elif op == "3":
        print(subtitulo("Diluição  C₁V₁ = C₂V₂"))
        print(info("Deixe 1 campo em branco para calcular."))
        C1 = input_num("C₁ — vazio para calcular", allow_empty=True)
        V1 = input_num("V₁ — vazio para calcular", allow_empty=True)
        C2 = input_num("C₂ — vazio para calcular", allow_empty=True)
        V2 = input_num("V₂ — vazio para calcular", allow_empty=True)
        try:
            if C1 is None:  print(result("C₁", f"{C2*V2/V1:.6f}"))
            elif V1 is None: print(result("V₁", f"{C2*V2/C1:.4f}"))
            elif C2 is None: print(result("C₂", f"{C1*V1/V2:.6f}"))
            elif V2 is None: print(result("V₂", f"{C1*V1/C2:.4f}"))
        except: print(err("Erro de cálculo."))

    elif op == "4":
        print(subtitulo("Título em Massa τ = m_soluto / m_solução"))
        ms = input_num("Massa do soluto (g)")
        mv = input_num("Massa do solvente (g)")
        msol = ms + mv
        tau = ms / msol
        resultado_box("TÍTULO EM MASSA", [
            f"Massa solução = {ms} + {mv} = {cor(str(msol), C.GREEN)} g",
            f"τ = {ms}/{msol} = {cor(f'{tau:.6f}', C.GREEN, C.BOLD)}",
            f"τ% = {cor(f'{tau*100:.4f}%', C.YELLOW)}",
        ])

    elif op == "5":
        print(subtitulo("Fração Molar X = n_soluto / (n_soluto + n_solvente)"))
        ms = input_num("Massa do soluto (g)")
        MMs = input_num("Massa Molar do soluto (g/mol)")
        mv = input_num("Massa do solvente (g)")
        MMv = input_num("Massa Molar do solvente (g/mol)", default=18.015)
        ns = ms / MMs
        nv = mv / MMv
        Xs = ns / (ns + nv)
        Xv = nv / (ns + nv)
        resultado_box("FRAÇÕES MOLARES", [
            f"n_soluto   = {ms}/{MMs} = {cor(f'{ns:.4f}', C.GREEN)} mol",
            f"n_solvente = {mv}/{MMv} = {cor(f'{nv:.4f}', C.GREEN)} mol",
            f"X_soluto   = {cor(f'{Xs:.6f}', C.GREEN, C.BOLD)}",
            f"X_solvente = {cor(f'{Xv:.6f}', C.CYAN)}",
        ])

    elif op == "6":
        print(subtitulo("Mistura de Soluções  C_f = (C₁V₁ + C₂V₂)/(V₁+V₂)"))
        C1 = input_num("C₁ (mol/L ou g/L)")
        V1 = input_num("V₁ (L)")
        C2 = input_num("C₂")
        V2 = input_num("V₂ (L)")
        Cf = (C1*V1 + C2*V2) / (V1+V2)
        resultado_box("CONCENTRAÇÃO FINAL", [
            f"C_f = ({C1}×{V1} + {C2}×{V2}) / ({V1}+{V2})",
            f"C_f = {cor(f'{Cf:.6f}', C.GREEN, C.BOLD)} (mesma unidade de entrada)",
        ])

    elif op == "7":
        print(subtitulo("Molalidade  m = n_soluto / m_solvente(kg)"))
        ns = input_num("Moles do soluto (mol) — ou massa/MM", allow_empty=True)
        massa_s = input_num("Massa do soluto (g) — vazio se já deu moles", allow_empty=True)
        MM_ = input_num("Massa Molar do soluto (g/mol) — vazio se já deu moles", allow_empty=True)
        mv_kg = input_num("Massa do solvente (kg)")
        if ns is None and massa_s is not None and MM_ is not None:
            ns = massa_s / MM_
        molal = ns / mv_kg
        print(result("Molalidade", f"{molal:.4f}", "mol/kg"))

