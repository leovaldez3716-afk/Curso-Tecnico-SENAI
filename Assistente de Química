def cinetica():
    print(titulo("CINÉTICA QUÍMICA"))
    print("  1. Velocidade Média              v = Δ[c] / Δt")
    print("  2. Meia-vida 1ª Ordem             t½ = 0,693 / k")
    print("  3. Meia-vida 2ª Ordem             t½ = 1 / (k·[A]₀)")
    print("  4. Concentração em função de t")
    print("  5. Van t Hoff (efeito temperatura) v₂/v₁ = Q^(ΔT/10)")
    print("  6. Equação de Arrhenius           k = A·e^(-Ea/RT)")
    print("  7. Tempo de reação (n meias-vidas)")
    print("  8. Voltar")
    R_ = 8.314
    op = input_str("Escolha")

    if op == "1":
        print(subtitulo("v = Δ[c] / Δt"))
        dc = input_num("Variação de concentração Δ[c] (mol/L)")
        dt = input_num("Variação de tempo Δt (s)")
        v = abs(dc)/dt
        print(result("Velocidade média", f"{v:.6f}", "mol/L·s"))

    elif op == "2":
        print(subtitulo("Meia-vida 1ª Ordem  t½ = ln2 / k = 0,693 / k"))
        k = input_num("Constante de velocidade k (s⁻¹) — ou vazio", allow_empty=True)
        t12 = input_num("Meia-vida t½ (s) — ou vazio", allow_empty=True)
        if k is None and t12 is not None: k = 0.693/t12; print(result("k", f"{k:.6f}", "s⁻¹"))
        elif t12 is None and k is not None: t12 = 0.693/k; print(result("t½", f"{t12:.4f}", "s"))
        else: print(err("Preencha apenas um campo."))

    elif op == "3":
        print(subtitulo("Meia-vida 2ª Ordem  t½ = 1/(k·[A]₀)"))
        k = input_num("Constante de velocidade k (L/mol·s)")
        A0 = input_num("[A]₀ — concentração inicial (mol/L)")
        t12 = 1 / (k * A0)
        print(result("t½", f"{t12:.4f}", "s"))

    elif op == "4":
        print(subtitulo("Concentração em função do tempo"))
        print(f"  {cor('1.', C.CYAN)} 1ª ordem: [A] = [A]₀·e^(-kt)  ou  [A]₀·(1/2)^(t/t½)")
        print(f"  {cor('2.', C.CYAN)} 2ª ordem: 1/[A] = 1/[A]₀ + kt")
        print(f"  {cor('3.', C.CYAN)} 0ª ordem: [A] = [A]₀ - kt")
        sub = input_str("Ordem")
        A0 = input_num("[A]₀ (mol/L)")
        k  = input_num("k (unidade da ordem)")
        t_ = input_num("t (s)")
        if sub == "1":
            At = A0 * math.exp(-k*t_)
            resultado_box("1ª ORDEM", [
                f"[A] = {A0}·e^(-{k}·{t_})",
                f"[A] = {cor(f'{At:.6f} mol/L', C.GREEN, C.BOLD)}",
                f"Consumido: {cor(f'{A0-At:.6f} mol/L', C.RED)}  ({(1-At/A0)*100:.2f}%)",
            ])
        elif sub == "2":
            At = 1 / (1/A0 + k*t_)
            print(result("[A](t)", f"{At:.6f}", "mol/L"))
        elif sub == "3":
            At = max(0, A0 - k*t_)
            print(result("[A](t)", f"{At:.6f}", "mol/L"))

    elif op == "5":
        print(subtitulo("Regra de Van't Hoff  v₂/v₁ = Q^(ΔT/10)"))
        Q_ = input_num("Coeficiente Q (geralmente 2 ou 3)", default=2)
        dT = input_num("ΔT (°C) = T₂ - T₁")
        razao = Q_ ** (dT/10)
        print(result("v₂/v₁", f"{razao:.4f}", "x"), info(f"A velocidade {'aumenta' if razao>1 else 'diminui'} {razao:.2f}x"))

    elif op == "6":
        print(subtitulo("Arrhenius  k = A·exp(-Ea/RT)"))
        A_ = input_num("Fator pré-exponencial A")
        Ea = input_num("Energia de ativação Ea (J/mol)")
        T_ = input_num("Temperatura T (K)")
        k  = A_ * math.exp(-Ea/(R_*T_))
        print(result("k", f"{k:.4e}", "s⁻¹"))
        # Comparação com dois T
        print()
        print(info("Calcular razão k₂/k₁ entre duas temperaturas:"))
        T1 = input_num("T₁ (K)")
        T2 = input_num("T₂ (K)")
        razao = math.exp((-Ea/R_) * (1/T2 - 1/T1))
        print(result("k₂/k₁", f"{razao:.4f}", "x"))

    elif op == "7":
        print(subtitulo("Quantidade restante após n meias-vidas"))
