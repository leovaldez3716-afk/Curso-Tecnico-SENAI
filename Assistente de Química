def termoquimica():
    print(titulo("TERMOQUÍMICA"))
    print("  1. Calorimetria            Q = m × c × ΔT")
    print("  2. Q = n × ΔH")
    print("  3. Lei de Hess             ΔH = ΣΔHf°(prod) - ΣΔHf°(reag)")
    print("  4. Energia de Ligação      ΔH = Σ E(quebradas) - Σ E(formadas)")
    print("  5. ΔG de Gibbs             ΔG = ΔH - TΔS")
    print("  6. Equilíbrio Térmico      m₁c₁ΔT₁ = m₂c₂ΔT₂")
    print("  7. Calores Específicos Comuns")
    print("  8. Voltar")
    op = input_str("Escolha")

    if op == "1":
        print(subtitulo("Q = m × c × ΔT"))
        print(info("Calores específicos: água=4,18 | ferro=0,449 | cobre=0,385 | alumínio=0,900"))
        m = input_num("Massa (g)")
        c = input_num("Calor específico c (J/g·°C)", default=4.18)
        Ti = input_num("Temperatura inicial Ti (°C)")
        Tf = input_num("Temperatura final Tf (°C)")
        dT = Tf - Ti
        Q = m * c * dT
        resultado_box("CALOR TROCADO", [
            f"ΔT = {Tf} - {Ti} = {cor(f'{dT:.2f} °C', C.CYAN)}",
            f"Q = {m} × {c} × {dT:.2f}",
            f"Q = {cor(f'{Q:.2f} J', C.GREEN, C.BOLD)}  =  {cor(f'{Q/1000:.4f} kJ', C.YELLOW)}  =  {cor(f'{Q/4.184:.2f} cal', C.BLUE)}",
            f"{'Reação ENDOTÉRMICA (Q > 0 — absorve calor)' if Q > 0 else 'Reação EXOTÉRMICA (Q < 0 — libera calor)'}",
        ])

    elif op == "2":
        print(subtitulo("Q = n × ΔH"))
        n_ = input_num("Número de moles (n)")
        dH = input_num("Entalpia ΔH (kJ/mol) — negativo se exotérmica")
        Q = n_ * dH
        print(result("Q", f"{Q:.4f}", "kJ"), info(f"Q = {n_} × {dH} = {Q:.4f} kJ"))

    elif op == "3":
        print(subtitulo("Lei de Hess  ΔHrxn = ΣΔHf°(produtos) - ΣΔHf°(reagentes)"))
        print(info("Insira os valores de ΔHf° e coeficientes separados por vírgula"))
        try:
            prod_dh = [float(x) for x in input_str("ΔHf° dos PRODUTOS (kJ/mol), ex: -393.5,-241.8").split(",")]
            prod_c  = [float(x) for x in input_str("Coeficientes dos PRODUTOS, ex: 1,2").split(",")]
            reag_dh = [float(x) for x in input_str("ΔHf° dos REAGENTES (kJ/mol), ex: 0,0").split(",")]
            reag_c  = [float(x) for x in input_str("Coeficientes dos REAGENTES, ex: 1,2").split(",")]
            sp = sum(dh*c for dh,c in zip(prod_dh, prod_c))
            sr = sum(dh*c for dh,c in zip(reag_dh, reag_c))
            dH = sp - sr
            resultado_box("LEI DE HESS", [
                f"ΣΔHf°(produtos)  = {cor(f'{sp:.2f} kJ', C.GREEN)}",
                f"ΣΔHf°(reagentes) = {cor(f'{sr:.2f} kJ', C.GREEN)}",
                f"ΔHrxn = {sp:.2f} - {sr:.2f} = {cor(f'{dH:.2f} kJ/mol', C.GREEN, C.BOLD)}",
                f"{'EXOTÉRMICA (ΔH < 0)' if dH < 0 else 'ENDOTÉRMICA (ΔH > 0)'}",
            ])
        except: print(err("Erro de entrada. Separe valores por vírgula sem espaços."))

    elif op == "4":
        print(subtitulo("Energia de Ligação  ΔH = Σ E(quebradas) - Σ E(formadas)"))
        print(info("Energias comuns (kJ/mol): H-H=436 | O=O=498 | H-O=463 | C-H=414 | C=O=799 | C-C=347 | C=C=614 | N≡N=945"))
