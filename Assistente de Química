def coligativas():
    print(titulo("PROPRIEDADES COLIGATIVAS"))
    print("  1. Ebulioscopia (Elevação Ebulição)     ΔTe = Ke × i × m")
    print("  2. Crioscopia (Abaixamento Fusão)        ΔTc = Kc × i × m")
    print("  3. Osmoscopia (Pressão Osmótica)         π = MRT")
    print("  4. Tonoscopia (Abaixamento de P. de Vapor)")
    print("  5. Calcular Massa Molar por ebulioscopio/crioscopio")
    print("  6. Fator i de Vant Hoff")
    print("  7. Tabela de Constantes dos Solventes")
    print("  8. Voltar")
    op = input_str("Escolha")
    R_ = 0.082

    def get_molalidade():
        ms = input_num("Massa de soluto (g)")
        MM_ = input_num("Massa Molar do soluto (g/mol)")
        mv = input_num("Massa de solvente (g)")
        return (ms/MM_)/(mv/1000)

    if op == "1":
        print(subtitulo("Ebulioscopia  ΔTe = Ke × i × m"))
        print(info("Solventes: Água Ke=0,512 | Benzeno Ke=2,53 | Clorofórmio Ke=3,63"))
        Ke = input_num("Ke do solvente (°C·kg/mol)")
        i_ = input_num("Fator de Van't Hoff i", default=1)
        m_ = input_num("Molalidade m (mol/kg) — ou vazio para calcular", allow_empty=True)
        if m_ is None: m_ = get_molalidade()
        dTe = Ke * i_ * m_
        pb  = input_num("Ponto de ebulição do solvente puro (°C) — vazio=pular", allow_empty=True)
        resultado_box("EBULIOSCOPIA", [
            f"ΔTe = {Ke} × {i_} × {m_:.4f}",
            f"ΔTe = {cor(f'{dTe:.4f} °C', C.GREEN, C.BOLD)}",
            f"Pe solução = {cor(f'{(pb+dTe):.2f} °C', C.YELLOW) if pb else cor('—', C.GRAY)}",
        ])
    elif op == "2":
        print(subtitulo("Crioscopia  ΔTc = Kc × i × m"))
        print(info("Água Kc=1,86 | Benzeno Kc=5,12 | Ciclohexano Kc=20,00 | Cânfora Kc=37,70"))
        Kc_ = input_num("Kc do solvente")
        i_  = input_num("Fator i", default=1)
        m_  = input_num("Molalidade m (mol/kg) — ou vazio", allow_empty=True)
        if m_ is None: m_ = get_molalidade()
        dTc = Kc_ * i_ * m_
        pf  = input_num("Pf do solvente puro (°C) — vazio=pular", allow_empty=True)
        resultado_box("CRIOSCOPIA", [
            f"ΔTc = {Kc_} × {i_} × {m_:.4f}",
            f"ΔTc = {cor(f'{dTc:.4f} °C', C.GREEN, C.BOLD)}",
            f"Pf solução = {cor(f'{(pf-dTc):.2f} °C', C.YELLOW) if pf else cor('—', C.GRAY)}",
        ])
    elif op == "3":
        print(subtitulo("Pressão Osmótica  π = MRT"))
        M_  = input_num("Molaridade M (mol/L)")
        T_  = input_num("T (K)")
        i_  = input_num("Fator i", default=1)
        pi  = i_ * M_ * R_ * T_
        print(result("π", f"{pi:.4f}", "atm"), info(f"= {pi*101.325:.2f} kPa"))
    elif op == "4":
        print(subtitulo("Tonoscopia  ΔP/P° = X_soluto"))
        P0  = input_num("Pressão de vapor do solvente puro P° (mmHg ou Pa)")
        X_s = input_num("Fração molar do soluto X_soluto")
        dP  = P0 * X_s
        print(result("ΔP (abaixamento)", f"{dP:.4f}"), info(f"P solução = {P0-dP:.4f}"))
    elif op == "5":
        print(subtitulo("Massa Molar por ebulioscopio/crioscopio"))
        tipo = input_str("Ebuliosc.(e) ou Criosc.(c)?").lower()
        K = input_num("Ke ou Kc do solvente")
        dT = input_num("ΔTe ou ΔTc observado (°C)")
        ms = input_num("Massa do soluto (g)")
        mv = input_num("Massa do solvente (g)")
        i_ = input_num("Fator i", default=1)
        # m = dT/(K*i)  →  n/kg = dT/(K*i)  →  n = dT*mv/(K*i*1000)  →  MM = ms/n
        m_ = dT/(K*i_)
        n_ = m_ * (mv/1000)
        MM_ = ms/n_
        resultado_box("MASSA MOLAR", [
            f"m = ΔT/(K×i) = {dT}/({K}×{i_}) = {cor(f'{m_:.4f} mol/kg', C.CYAN)}",
            f"n = m × kg_solvente = {m_:.4f} × {mv/1000} = {cor(f'{n_:.4f} mol', C.CYAN)}",
            f"MM = ms/n = {ms}/{n_:.4f} = {cor(f'{MM_:.2f} g/mol', C.GREEN, C.BOLD)}",
        ])
    elif op == "6":
        print(subtitulo("Fator de Van't Hoff  i = 1 + (n-1)·α"))
        
